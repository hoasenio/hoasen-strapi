{
  "kind": "collectionType",
  "collectionName": "skills",
  "info": {
    "singularName": "skill",
    "pluralName": "skills",
    "displayName": "Skill"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "bg_color_code": {
      "type": "string",
      "minLength": 7,
      "maxLength": 7
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "text_color_code": {
      "type": "string",
      "minLength": 7,
      "maxLength": 7
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "mappedBy": "skills"
    }
  }
}
