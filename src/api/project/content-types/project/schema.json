{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "domain_subtitle": {
      "type": "string"
    },
    "short_description": {
      "type": "text",
      "required": true
    },
    "is_featured": {
      "type": "boolean",
      "default": true
    },
    "logo_icon": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "thumbnail_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "brief_and_background": {
      "type": "component",
      "component": "shared.brief-background",
      "repeatable": false
    },
    "team_members": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team-member.team-member",
      "inversedBy": "projects"
    },
    "gallery_images": {
      "type": "component",
      "component": "shared.media",
      "repeatable": true
    },
    "industries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::industry.industry",
      "mappedBy": "projects"
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "inversedBy": "projects"
    },
    "robots_txt": {
      "type": "text"
    },
    "llm_txt": {
      "type": "text"
    },
    "stats": {
      "type": "component",
      "component": "shared.stat",
      "repeatable": true
    },
    "business_objectives": {
      "type": "component",
      "component": "shared.business-objective",
      "repeatable": true
    },
    "solutions": {
      "type": "component",
      "component": "shared.solution",
      "repeatable": true
    },
    "outcome": {
      "type": "component",
      "component": "shared.outcome",
      "repeatable": false
    },
    "testimonial": {
      "type": "component",
      "component": "shared.testimonial",
      "repeatable": false
    },
    "tech_infra_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tech-infra-item.tech-infra-item",
      "inversedBy": "projects"
    }
  }
}
