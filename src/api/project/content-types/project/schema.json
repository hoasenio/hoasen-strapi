{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "short_description": {
      "type": "text",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "is_featured": {
      "type": "boolean",
      "default": true
    },
    "overview": {
      "type": "richtext"
    },
    "logo_icon": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "domain_subtitle": {
      "type": "string"
    },
    "team_members": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team-member.team-member",
      "inversedBy": "projects"
    },
    "media_stack": {
      "type": "component",
      "component": "shared.media",
      "repeatable": true
    },
    "industries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::industry.industry",
      "mappedBy": "projects"
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "inversedBy": "projects"
    },
    "robots_txt": {
      "type": "text"
    },
    "llm_txt": {
      "type": "text"
    }
  }
}
